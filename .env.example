# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- AWS / S3 (used by scripts/events_upload.py, matches_upload.py) ---
BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# --- WhoScored local export (source folders the upload scripts read from) ---
# SEASON labels manual WhoScored uploads. fpl_snapshot.py ignores it unless
# set explicitly -- it derives the season from the API payload instead.
SEASON=2025
LOAD_DATE=
EVENTS_FOLDER=
MATCHES_FOLDER=

# --- MotherDuck (used by app/streamlit_app.py and the Airflow dbt tasks) ---
# Get a token at https://motherduck.com after signing up (free tier).
MOTHERDUCK_TOKEN=

# --- Airflow (docker-compose local stack) ---
# Encrypts connections/variables in the metadata DB. Must stay stable across
# restarts or previously stored connections become undecryptable. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Signs webserver session cookies. Local-only UI, so a fixed dev value is fine.
AIRFLOW_SECRET_KEY=dev-only-not-secure
